# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=minimum_32_chars_random_string
JWT_REFRESH_SECRET=another_minimum_32_chars_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (Prisma)
DATABASE_URL=postgresql://user:password@host:5432/bastion

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# AWS (used server-side only — prefer Secrets Manager in production)
AWS_REGION=us-east-1
AWS_S3_BUCKET=bastion-uploads
